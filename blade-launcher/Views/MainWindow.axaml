<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:blade_launcher.ViewModels"
        xmlns:models="using:blade_launcher.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="450"
        x:Class="blade_launcher.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/blade.png"
        Title="Blade Launcher"
        Width="680" Height="420"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        WindowDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="AcrylicBlur, Transparent">

    <Border CornerRadius="12"
            Background="#18181B"
            BorderBrush="#27272A"
            BorderThickness="1"
            Padding="16">

        <Grid RowDefinitions="Auto, *">
            
            <!-- Row 0: Search Bar Input -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto, *">
                <TextBlock Grid.Column="0" 
                           Text="🗡️" 
                           FontSize="18" 
                           VerticalAlignment="Center" 
                           Margin="8,0,12,0"/>

                <!-- Fixed Warning: Watermark -> PlaceholderText -->
                <TextBox Grid.Column="1"
                         Name="SearchInput"
                         Text="{Binding SearchQuery, Mode=TwoWay}"
                         PlaceholderText="Search apps or commands..."
                         FontSize="18"
                         Padding="10,8"
                         Background="#27272A"
                         Foreground="#FAFAFA"
                         BorderThickness="0"
                         CornerRadius="8"/>
            </Grid>

            <!-- Row 1: App Grid / Panel Content Area -->
            <ScrollViewer Grid.Row="1" Margin="0,16,0,0">
                <ItemsControl ItemsSource="{Binding FilteredApps}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <!-- DataTemplate for AppEntry -->
                    <ItemsControl.ItemTemplate>
                        <!-- Fixed Errors: Added explicit x:DataType for the DataTemplate items -->
                        <DataTemplate x:DataType="models:AppEntry">
                            <Button Width="110" Height="100"
                                    Margin="6"
                                    Padding="8"
                                    Background="#27272A"
                                    CornerRadius="10"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center">
                                
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border Width="48" Height="48" 
                                            CornerRadius="8" 
                                            Background="#3F3F46" 
                                            Margin="0,0,0,8"
                                            HorizontalAlignment="Center">
                                        <TextBlock Text="⚡" 
                                                   FontSize="20" 
                                                   HorizontalAlignment="Center" 
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    
                                    <!-- Now resolves AppEntry.Name cleanly -->
                                    <TextBlock Text="{Binding Name}" 
                                               Foreground="#E4E4E7" 
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               HorizontalAlignment="Center"
                                               MaxWidth="90"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            
        </Grid>
    </Border>
</Window>